    {
      "name": "Votes",
      "item": [
        {
          "name": "Votar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 o 400 (ya votó)', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 400]);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    pm.test('Voto registrado correctamente', () => {",
                  "        pm.expect(pm.response.json().message).to.eql('Vote recorded');",
                  "    });",
                  "}",
                  "",
                  "if (pm.response.code === 400) {",
                  "    pm.test('Mensaje de doble voto', () => {",
                  "        pm.expect(pm.response.json().error).to.include('already voted');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"survey_id\": {{survey_id}},\n  \"option_id\": {{option_id}}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/votes",
              "host": ["{{base_url}}"],
              "path": ["api", "votes"]
            },
            "description": "Registra el voto del usuario autenticado.\n\n**Nota de seguridad (IDOR):** El `user_id` se obtiene del token JWT. Aunque se envíe en el body, es completamente ignorado — no es posible votar en nombre de otro usuario.\n\n**Restricción:** Un usuario solo puede votar una vez por encuesta."
          },
          "response": [
            {
              "name": "201 Voto registrado",
              "originalRequest": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{token}}" },
                  { "key": "Content-Type", "value": "application/json" }
