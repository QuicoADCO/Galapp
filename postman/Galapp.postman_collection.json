        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Respuesta contiene token JWT', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('token');",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    const parts = json.token.split('.');",
                  "    pm.expect(parts).to.have.lengthOf(3);",
                  "});",
                  "",
                  "// Guardar el token en la variable de entorno para el resto de requests",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.environment.set('token', json.token);",
                  "    console.log('Token guardado en variable {{token}}');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin1234!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Inicia sesión y obtiene un token JWT (válido 1 hora).\n\nEl script de test **guarda automáticamente** el token en la variable `{{token}}` del environment. A partir de aquí todos los endpoints protegidos funcionarán sin configuración adicional.\n\n**Rate limit:** 10 peticiones/min por IP"
          },
          "response": [
            {
              "name": "200 OK — Token JWT",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin1234!\"\n}" },
                "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "cookie": [],
              "body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwidXNlcm5hbWUiOiJhZG1pbiIsInJvbGUiOiJhZG1pbiIsImV4cCI6MTcwMDAwMDAwMH0.signature\"\n}"
            },
            {
              "name": "401 Credenciales inválidas",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
